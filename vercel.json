{
  "version": 2,
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    {
      "src": "/api/functions.php",
      "status": 403,
      "dest": "/"
    },
    {
      "src": "/(.*\\.(png|jpg|jpeg|gif|webp|svg|ico))",
      "dest": "/api/$1"
    },
    {
      "src": "/api/(.*)\\.php",
      "dest": "/api/$1.php"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}
